	)
	(text "Servo Switch"
		(exclude_from_sim no)
		(at 90.678 88.392 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "5a12ccac-e5ce-4826-9808-70483b9cb58b")
	)
	(text "Protection primarily happens through the 1k resistor\nwhich limits the current when the servo is plugged backwards.\nThe TVS Diode is an additional safeguard in case the 1k resistor\nis not enough, the voltage rise on the GPIO pin will be clamped\nto 3.5V."
		(exclude_from_sim no)
		(at 80.772 157.988 0)
		(effects
			(font
				(size 0.72 0.72)
			)
		)
		(uuid "6a3277cd-d884-4d7d-ba31-44b634b63cd0")
	)
	(text "Servo power on"
		(exclude_from_sim no)
		(at 120.904 65.024 0)
		(effects
			(font
				(size 1.27 1.27)
				(color 194 0 194 1)
			)
		)
		(uuid "6ce697f1-3054-4613-9ff8-dddf7597fb7b")
	)
	(text "Servo switched on"
		(exclude_from_sim no)
		(at 122.428 53.594 0)
		(effects
			(font
				(size 1.27 1.27)
				(color 194 0 194 1)
			)
		)
		(uuid "75819ddb-fb98-48cd-946c-5b51b505fcce")
	)
	(text "Detection is done based on the potential difference created\nfrom the current flow when the servo is plugged in backwards.\nThis can be bi-directional (Pi <-> Servo). Any difference is\namplified 20x by the IC (clamped to 3.3V max)."
		(exclude_from_sim no)
		(at 80.01 163.83 0)
		(effects
			(font
				(size 0.72 0.72)
			)
		)
		(uuid "76802eba-73ef-4389-8b82-9b460860c1f3")
	)
	(text "Only USB-C power"
		(exclude_from_sim no)
		(at 58.166 54.102 0)
		(effects
			(font
				(size 1.27 1.27)
				(color 194 0 194 1)
			)
		)
		(uuid "85872cfb-ddb4-4915-99f5-bcf5342f2f20")
	)
	(text "RC filter for when the Pi is sending PWM/UART and\nservo is connected backwards (since the chip is unidirectional)"
